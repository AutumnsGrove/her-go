# Debug mode: when true, logs full API request/response bodies to her.log
debug: false

identity:
  her: "Mira"      # the bot's name — injected into prompts as {{her}}
  user: "Autumn"    # your name — injected into prompts as {{user}}

telegram:
  token: "${TELEGRAM_BOT_TOKEN}"
  mode: "poll"        # "poll" (long-polling, default) or "webhook" (CF Worker forwards updates to us)
  webhook_url: ""     # public URL registered with Telegram — set by CF Worker deploy, not the bot
  webhook_port: 8443  # local port for webhook HTTP server (only used in webhook mode)
  webhook_secret: ""  # shared secret validated via X-Telegram-Bot-Api-Secret-Token header
  owner_chat: 0       # your Telegram chat ID — needed for scheduled reminders. Send /status to the bot to find it.

openrouter:
  base_url: "https://openrouter.ai/api/v1"
  api_key: "${OPENROUTER_API_KEY}"

chat:
  model: "xiaomi/mimo-v2.5-pro"    # reply model — MiMo v2.5 Pro via xiaomi/fp8: excellent cache rate, natural voice
  temperature: 0.85
  max_tokens: 4096
  timeout: 30
  streaming: false                   # set true to stream reply tokens to Telegram (live typing effect)
  provider:
    order: ["xiaomi/fp8"]            # pin to xiaomi/fp8 for ~80% prompt cache hit rate
  fallback:
    model: "google/gemini-3.1-flash-lite"
    temperature: 0.85
    max_tokens: 4096

driver:
  model: "xiaomi/mimo-v2.5"                      # MiMo v2.5 — reasoning model with internal chain-of-thought, excellent cache rate on xiaomi/fp8
  temperature: 0.4                               # standard transformer, moderate temp for varied but controlled tool calling
  max_tokens: 4096                               # raised from 2048 — streaming abort prevents batched tool calls but this is a safety net
  timeout: 60                                    # HTTP timeout in seconds (default 60)
  trace: false                                   # show driver agent thinking traces in chat (/traces to toggle)
  # require_tool_choice: true                    # force tool_choice="required" on first agent call (default true). Set false for models/providers that don't support tool_choice.
  max_replies_per_turn: 2                        # hard cap on reply calls per user message (default 2)
  fast_path: false                               # route simple messages (greetings, reactions) directly to chat model, skipping driver agent
  provider:
    order: ["xiaomi/fp8"]
  fallback:
    model: "google/gemini-3.1-flash-lite"
    temperature: 0.1
    max_tokens: 2048

classifier:
  model: "google/gemini-3.1-flash-lite"  # small, fast model for memory + reply safety gates
  temperature: 0.15                               # slight flex for nuanced safety judgments (escalation vs. mirroring)
  max_tokens: 64                                  # only needs ~20 tokens, 64 for safety margin

memory_agent:
  model: "xiaomi/mimo-v2.5"           # MiMo v2.5 — reliable tool-calling, excellent cache rate on xiaomi/fp8
  temperature: 0.3                    # moderate temp for varied but controlled fact extraction
  max_tokens: 4096                    # generous headroom for tool call sequences
  timeout: 120                        # 120s — memory agent processes long transcripts
  provider:
    order: ["xiaomi/fp8"]

persona_agent:
  model: "xiaomi/mimo-v2.5"           # MiMo v2.5 — persona evolution. Falls back to memory_agent if empty.
  temperature: 0.5                     # moderate creativity for persona prose
  max_tokens: 2048                     # persona output is short — 2K is plenty
  timeout: 120                         # reflections process long context

dream_agent:
  model: "xiaomi/mimo-v2.5"           # MiMo v2.5 — memory dreamer consolidation. Falls back to memory_agent if empty.
  temperature: 0.3                     # low temp for analytical merge/expire decisions
  max_tokens: 4096                     # needs room for tool call sequences
  timeout: 120                         # processes all active memories
  provider:
    order: ["xiaomi/fp8"]

vision:
  model: "xiaomi/mimo-v2.5"           # MiMo v2.5 — multimodal, handles image understanding
  temperature: 0.3                         # low temp for accurate descriptions
  max_tokens: 512
  provider:
    order: ["xiaomi/fp8"]
  fallback:
    model: "google/gemini-3.1-flash-lite"
    temperature: 0.3
    max_tokens: 512

embed:
  base_url: "http://localhost:11434/v1"                         # Ollama (recommended) or any OpenAI-compatible embedding server
  model: "nomic-embed-text"                                    # Ollama model name (run: ollama pull nomic-embed-text)
  dimension: 768                                                # vector size — must match your model (768 for nomic, 1536 for OpenAI, etc.)
  similarity_threshold: 0.85                                    # above this = duplicate fact (0.0-1.0)
  max_semantic_distance: 0.45                                   # facts farther than this skip auto-injection into context (0=identical, 1=unrelated). Lower is stricter.
  # For LM Studio instead: base_url: "http://localhost:1234/v1", model: "text-embedding-nomic-embed-text-v1.5@q8_0"

search:
  # SearXNG is a free, self-hosted meta-search engine. If configured, web_search
  # uses this instead of Tavily (no API key, no rate limits, includes thumbnails).
  # Example: http://localhost:8888 if running locally via Docker.
  searxng_base_url: ""  # optional — leave empty to use Tavily

  tavily_api_key: "${TAVILY_API_KEY}"
  tavily_base_url: "https://api.tavily.com"  # default, rarely needs changing

foursquare:
  api_key: "${FOURSQUARE_API_KEY}"  # Foursquare Places API (Service API Key). Free tier: 10k calls/month. Generate at https://foursquare.com/developers → Settings → Service API Keys

polaris:
  # Polaris is a separate self-hosted research agent — enables the
  # polaris_search tool, which does its own multi-step web search +
  # synthesis and returns one finished, cited answer. Always co-located
  # with her-go (same machine, whether that's a dev box or the potato),
  # so this is always localhost. Leave empty to disable the tool entirely.
  base_url: "http://localhost:8899"

mood_agent:
  # MiMo v2.5 — structured JSON output for mood schema.
  # Reasoning is auto-disabled for mood (plain JSON extraction task).
  # Empty model disables the post-turn mood agent entirely.
  model: "xiaomi/mimo-v2.5"
  temperature: 0.2
  max_tokens: 512
  timeout: 60
  provider:
    order: ["xiaomi/fp8"]

introspection_agent:
  # MiMo v2.5 — self-reflection agent, runs after memory + mood.
  # Empty model falls back to memory_agent model.
  model: "xiaomi/mimo-v2.5"
  temperature: 0.3
  max_tokens: 2048
  timeout: 60
  iterations_per_window: 5   # smaller than other agents — should be fast
  max_continuations: 1       # one window is enough, skip or save and move on
  provider:
    order: ["xiaomi/fp8"]

mood:
  # Point at a custom vocab file to override Apple's embedded lists.
  # Empty → use mood/vocab.yaml embedded at build time.
  vocab_path: ""
  context_turns: 5               # how many recent turns the agent sees
  confidence_high: 0.75          # ≥ this → auto-log as source=inferred
  confidence_low: 0.40           # < this → drop silently
  dedup_window_minutes: 120      # KNN dedup lookback
  dedup_similarity: 0.80         # cosine similarity threshold for "same mood"
  proposal_expiry_minutes: 30    # how long a Telegram proposal stays tappable
  sweeper_interval_minutes: 5    # how often the expiry sweeper runs
  daily_rollup_cron: "0 21 * * *"  # 21:00 local — end-of-day rollup
  session_gap_minutes: 240         # gap (minutes) between messages that marks a session boundary — stale turns excluded from mood inference
  # classifier is the unified cfg.classifier.model — same model across
  # memory writes and mood writes, no separate knob.

memory:
  db_path: "./her.db"
  recent_messages: 6             # sliding window size (compaction summaries cover older context)
  max_facts_in_context: 10       # top-K facts to inject
  extraction_interval: 10        # extract facts every N messages
  max_history_tokens: 8000       # message history token budget — compaction fires at 75% of this (6000 tokens). System prompt excluded.
  driver_context_budget: 16000   # driver model action history budget — when accumulated tool call history exceeds 75% of this, older actions get summarized. 0 = use 6000 default.
  auto_link_count: 3             # max links per new memory (0 = disabled). Links connect related memories into a knowledge graph.
  auto_link_threshold: 0.7       # min cosine similarity to create a link (0.0-1.0). Higher = stricter, fewer links.
  max_memory_length: 1000        # hard character limit per memory. Raised from 300 to support dream consolidation merges. The SPLIT classifier catches packed memories before this fires.

  # Blended retrieval scoring — weights for the formula that ranks memories
  # by a blend of similarity, importance, recency, and usage frequency.
  # Similarity still dominates; importance + recency + usage act as tiebreakers
  # that promote well-used, recent, high-importance memories over raw distance.
  recall:
    similarity_weight: 0.60       # cosine similarity contribution
    importance_weight: 0.25       # importance score (1-10, normalized to 0-1)
    recency_weight: 0.15          # exponential decay on memory age
    recency_half_life_days: 30    # half-life for recency decay (days)
    usage_boost_factor: 0.10      # boost from recall_count (log-scaled, diminishing returns)

scrub:
  enabled: true
  # tier 1 (hard redact) and tier 2 (tokenize) are always on
  # tier 3 (names, places, context) passes through by design

persona:
  prompt_file: "./prompt.md"
  persona_file: "./persona.md"
  agent_prompt_file: "./driver_agent_prompt.md"
  rewrite_every_n_reflections: 3     # legacy — unused once dreamer is running, kept for /reflect command
  reflection_memory_threshold: 8     # legacy — unused once dreamer is running
  max_trait_shift: 0.1               # max trait score change per rewrite cycle
  dream_hour: 4                      # hour (0-23) to run nightly reflection (4 = 04:00 local time)
  min_rewrite_days: 7                # minimum days between persona rewrites
  min_reflections: 3                 # minimum unconsumed reflections required before a rewrite is allowed

dream:
  cluster_threshold: 0.70             # cosine similarity for memory clustering (lower = bigger clusters)
  max_operations: 20                  # max tool calls per dream cycle (safety cap)
  dry_run: false                      # true = log what would change without touching DB
  # enabled: true                     # master switch — omit or set true to enable

  # Conservative forgetting: hard rules in code prevent the dreamer from
  # removing protected, important, recent, or actively-used memories.
  # Even when all conditions are met, removals are capped per cycle.
  forgetting:
    enabled: true
    max_removes_per_cycle: 5          # hard ceiling per nightly dream
    require_low_importance: 3         # only memories with importance <= this
    min_age_days: 60                  # eligible only after 60 days
    min_unused_days: 60               # eligible only if unused for 60 days

  # Tomorrow's preload: the dream cycle writes a short note about what
  # to bring up in the next conversation. Auto-injected into the first
  # chat turn of the day, then consumed.
  tomorrow_preload:
    enabled: true
    expires_after_hours: 48           # how long the note stays active
    history_lookback_days: 7          # how many days of messages to scan

# Background agent batching — controls when memory, mood, and introspection
# agents run after each turn. Instead of firing on every message, a substance
# gate skips casual exchanges ("lol", "ok", "brb") and a counter forces a
# batch after a threshold so nothing is lost. Saves LLM calls on low-value turns.
background_agents:
  batch_threshold: 3     # max skipped turns before forced batch (0 = use default 3)
  substance_gate: true   # use classifier to detect substantive turns

location:
  latitude: 0                   # written by set_location — leave 0/0 until set
  longitude: 0
  name: ""                      # display name from the last geocoding (e.g., "Portland, Oregon")
  temp_unit: "fahrenheit"       # "fahrenheit" or "celsius"
  wind_unit: "mph"              # "mph" or "kmh"

voice:
  enabled: false                                                  # set true to accept voice memos
  stt:
    # Local engine (Apple Silicon / macOS only — uses MLX):
    engine: "parakeet"                                            # spawns parakeet-mlx-fastapi sidecar automatically
    base_url: "http://localhost:8765"
    model: "mlx-community/parakeet-tdt-0.6b-v2"
    # Remote engine (any platform — good for VPS):
    # engine: "whisper"
    # base_url: "https://openrouter.ai/api/v1"
    # model: "openai/whisper-large-v3-turbo"
    # api_key: ""                                                 # leave empty to auto-use openrouter.api_key
    fallback_model: "openai/whisper-large-v3"                     # fallback on timeout/503 (more reliable than turbo)
  tts:
    enabled: false                                                # set true to reply with voice
    # Local engine (privacy-first, zero API cost, lower quality):
    engine: "piper"
    base_url: "http://localhost:8766"                              # Piper TTS server URL
    model: "en_GB-southern_english_female-low"                     # Piper voice model (HuggingFace ID or local path)
    voice_id: "en_GB-southern_english_female-low"                  # Voice preset (for Piper, same as model)
    idle_unload_sec: 300                                          # piper: unload the model after this many idle seconds to free ~120MB RAM; 0 = never unload
    # Remote engine (much higher quality, costs per character, needs internet):
    # engine: "elevenlabs"
    # voice_id: ""                                                # from the voice's page in the ElevenLabs voice library — it's the `voiceId` query param in the URL
    # model: "eleven_flash_v2_5"                                  # low-latency default; leave unset to use it automatically
    # api_key: ""                                                 # your ElevenLabs API key
    # fallback:                                                   # auto-retry with piper if elevenlabs fails (API error, network issue, or free-tier credits run out mid-month)
    #   engine: "piper"
    #   base_url: "http://localhost:8766"
    #   model: "en_GB-southern_english_female-low"
    #   voice_id: "en_GB-southern_english_female-low"
    #   idle_unload_sec: 300                                      # keep this >0 so the fallback sidecar isn't sitting resident 24/7 for a path that's rarely used
    speed: 1.0                                                    # Speaking rate (1.0 = normal) — piper only
    reply_mode: "voice"                                           # "voice" (always voice reply) or "match" (reply in same format as input)
    pauses:                                                       # Silence durations (ms) inserted at punctuation boundaries — piper only
      paragraph_ms: 500                                           # between paragraphs (double newlines)
      line_ms: 250                                                # between single newlines
      sentence_ms: 75                                             # after . ! ?
      comma_ms: 50                                                # after ,
      semi_ms: 30                                                 # after ; :

calendar:
  # Path to the Swift EventKit bridge binary. Relative paths are resolved from
  # the project root. If missing at startup, calendar tools return errors but
  # the bot continues running (fail-soft pattern).
  bridge_path: "calendar/bridge/.build/release/her-calendar"

  # List of calendars to monitor (reads events from all of these).
  # Calendar names must match exactly as they appear in Apple Calendar.
  # The calendar_list tool queries all of these and returns a unified timeline.
  calendars:
    - "Calendar"     # Default Apple Calendar
    - "Work"
    - "Testing"

  # Default calendar for creating new events (must be in the calendars list above).
  # Tools can override this on a per-event basis by specifying the calendar field.
  default_calendar: "Calendar"

  # Timezone for get_time tool and naive timestamp interpretation. Also used
  # by agent_time layer when set (otherwise falls back to system timezone).
  # Format: IANA timezone database name (e.g., "America/New_York", "Europe/London").
  default_timezone: "America/New_York"

  # Known jobs for shift tracking. When the agent passes a "job" param to
  # calendar_create, the handler validates the name against this list and
  # auto-fills defaults (address → location, default_role → position).
  # Add or remove freely — code never references these by name.
  jobs:
    - name: "Panera"
      address: "3625 Spring Hill Pkwy SE, Smyrna, GA 30080"
      default_role: ""              # blank = read role from schedule text
      aliases: ["panera bread"]

    - name: "Cava"
      address: "855 Peachtree St NE, Atlanta, GA 30308"
      default_role: "Grill Cook"
      aliases: []

# Cloudflare Tunnel — used for always-on deployment. The tunnel creates a
# stable public HTTPS URL that routes to the local webhook server, even behind
# NAT. Only needed when mode is "webhook". Run `her tunnel setup` to configure.
tunnel:
  name: ""                # tunnel name from `cloudflared tunnel create` (e.g., "her-prod")
  domain: ""              # public hostname routed to this tunnel (e.g., "her.yourdomain.com")
  credentials_file: ""    # path to tunnel credentials JSON — auto-filled by `her tunnel setup`

# Cloudflare API credentials for KV routing and D1 shared state sync.
# account_id and api_token are needed on both machines.
# kv_namespace_id is for dev mode routing (`her dev`).
# d1_database_id enables cross-machine sync — leave empty to disable.
cloudflare:
  account_id: ""          # Cloudflare account ID (dashboard URL: /accounts/<this>/...)
  api_token: ""           # API token with Workers KV + D1 write permission
  kv_namespace_id: ""     # KV namespace ID (from wrangler.toml after `npx wrangler kv namespace create`)
  d1_database_id: ""      # D1 database ID — empty = sync disabled, SyncedStore not used
  sync:                    # D1 sync tuning (all optional — sane defaults if omitted)
    batch_size: 50           # max rows per D1 batch push
    carrier_poll_seconds: 2  # outbox check interval
    pull_page_size: 500      # rows per D1 pull query
    poller_interval: 30      # KV poller check interval (prod only, seconds)
    startup_pull_timeout: 60 # startup pull timeout (seconds)
    push_timeout: 600        # her sync push timeout (seconds)
    pull_timeout: 300        # her sync pull timeout (seconds)

# Self-update via /update Telegram command. Only used on the Mac Mini
# production instance — pulls latest code, builds, and restarts via launchd.
update:
  repo_path: ""                    # path to the git repo (default: working directory). Set this on the Mac Mini.
  service_label: "com.mira.her-go" # launchd service label — must match the Label key in your .plist

# Gateway: multi-adapter transport layer. Each adapter entry runs
# independently with its own DB, memory toggle, and platform-specific settings.
# Two adapters pointing to the same DB share facts/mood/persona.
# Different DB paths = fully isolated (great for testing).
#
# Without this section, the bot runs in legacy mode (direct Telegram via
# the telegram: config above). Add adapters here to use the gateway.
gateway:
  adapters:
    # Telegram adapter — production messaging via Telegram Bot API.
    # Uses the token from the telegram: section above if not overridden here.
    - name: telegram
      type: telegram
      db: her.db
      memory: true
      token: "${TELEGRAM_BOT_TOKEN}"
      mode: "poll"

    # Gradio adapter — local development chat UI with trace panel.
    # Run `her run --adapter=gradio` for dev work without touching Telegram.
    - name: gradio-dev
      type: gradio
      enabled: false               # enable when you want local dev chat
      db: her-dev.db               # separate DB so dev chat doesn't pollute production
      memory: false                # disable memory for quick testing
      port: 7777                   # Go API port — Gradio Python UI runs separately on :7860
      traces: true                 # show agent traces in side panel

# --- Worker Agent ---
# Background worker that produces file artifacts (briefings, research reports).
# Model tiers allow different quality/cost tradeoffs per task type.
# Each task type's meta.yaml declares which tier it uses.
# Gmail integration — read-only API access for email triage.
# One-time setup: create OAuth credentials in Google Cloud Console,
# enable Gmail API, get tokens from OAuth Playground (developers.google.com/oauthplayground).
# Push Cloud Console app to "Production" so refresh tokens don't expire after 7 days.
gmail:
  client_id: ""                    # from Google Cloud Console (Desktop app type)
  client_secret: ""                # from Google Cloud Console
  refresh_token: ""                # from OAuth Playground (gmail.readonly scope)
  account: ""                      # display label, e.g. "triage@gmail.com"
  max_results: 20                  # emails per page in search results

worker_agent:
  telegraph_token: ""              # from telegra.ph API — empty = skip publishing
  reports_dir: "reports"           # relative to project root
  tiers:
    low:
      model: "xiaomi/mimo-v2.5"
      temperature: 0.7
      max_tokens: 8192
      provider:
        order: ["xiaomi/fp8"]
    medium:
      model: "deepseek/deepseek-v4-flash"
      temperature: 0.7
      max_tokens: 16384
    high:
      model: "xiaomi/mimo-v2.5-pro"
      temperature: 0.7
      max_tokens: 32768
      provider:
        order: ["xiaomi/fp8"]
