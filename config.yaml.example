telegram:
  token: "${TELEGRAM_BOT_TOKEN}"
  mode: "poll"  # "poll" or "webhook"
  webhook_url: ""  # only needed for webhook mode
  owner_chat: 0    # your Telegram chat ID — needed for scheduled reminders. Send /status to the bot to find it.

llm:
  base_url: "https://openrouter.ai/api/v1"
  api_key: "${OPENROUTER_API_KEY}"
  model: "deepseek/deepseek-v3.2"
  temperature: 0.85
  max_tokens: 1024

agent:
  model: "arcee-ai/trinity-large-preview:free"  # tool-calling model for memory management
  temperature: 0.1                              # low temp for precise tool decisions
  max_tokens: 512

vision:
  model: "google/gemini-3-flash-preview"  # VLM for image understanding (via OpenRouter, same base_url/api_key as llm)
  temperature: 0.3                         # low temp for accurate descriptions
  max_tokens: 512

embed:
  base_url: "http://localhost:1234/v1"                          # LM Studio / Ollama / any OpenAI-compatible embedding server
  model: "text-embedding-nomic-embed-text-v1.5@q8_0"           # local embedding model
  similarity_threshold: 0.85                                    # above this = duplicate fact (0.0-1.0)

search:
  tavily_api_key: "${TAVILY_API_KEY}"
  tavily_base_url: "https://api.tavily.com"  # default, rarely needs changing

memory:
  db_path: "./her.db"
  recent_messages: 20       # sliding window size
  max_facts_in_context: 10  # top-K facts to inject
  extraction_interval: 10   # extract facts every N messages
  max_history_tokens: 8000  # token budget for conversation history — compaction triggers at 75% of this

scrub:
  enabled: true
  # tier 1 (hard redact) and tier 2 (tokenize) are always on
  # tier 3 (names, places, context) passes through by design

persona:
  prompt_file: "./prompt.md"             # base template (static, user-authored)
  persona_file: "./persona.md"           # evolving self-image (bot-authored)
  agent_prompt_file: "./agent_prompt.md" # agent orchestration rules (editable, hot-reloadable)
  rewrite_every_n_conversations: 3  # trigger persona rewrite after N reflections accumulate
  reflection_memory_threshold: 10  # trigger reflection after N new facts accumulate since last reflection
  max_trait_shift: 0.1             # max trait score change per rewrite cycle

scheduler:
  timezone: "America/New_York"     # IANA timezone — cron expressions evaluated in this zone
  quiet_hours_start: "23:00"       # v0.6: no scheduled messages during this window
  quiet_hours_end: "07:00"         # v0.6: resume after this time
  max_proactive_per_day: 5         # v0.6: cap on non-reminder scheduled messages

voice:
  enabled: false                                                  # set true to accept voice memos
  stt:
    engine: "parakeet"                                            # "parakeet" or "cf-workers-ai"
    base_url: "http://localhost:8765"                              # parakeet-mlx-fastapi server
    model: "mlx-community/parakeet-tdt-0.6b-v2"                   # HuggingFace model ID or local path
  tts:
    enabled: false                                                # set true to reply with voice
    engine: "kokoro"                                              # "kokoro" or future options
    base_url: "http://localhost:8766"                              # mlx-audio server
    model: "mlx-community/Kokoro-82M-bf16"                        # HuggingFace model ID or local path
    voice_id: "af_heart"                                          # voice preset (see VOICES.md in model repo)
    speed: 1.0                                                    # speaking rate (1.0 = normal)
    reply_mode: "voice"                                           # "voice" (always voice reply) or "match" (reply in same format as input)
