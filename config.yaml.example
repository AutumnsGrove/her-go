identity:
  her: "Mira"      # the bot's name — injected into prompts as {{her}}
  user: "Autumn"    # your name — injected into prompts as {{user}}

telegram:
  token: "${TELEGRAM_BOT_TOKEN}"
  mode: "poll"  # "poll" or "webhook"
  webhook_url: ""  # only needed for webhook mode
  owner_chat: 0    # your Telegram chat ID — needed for scheduled reminders. Send /status to the bot to find it.

llm:
  base_url: "https://openrouter.ai/api/v1"
  api_key: "${OPENROUTER_API_KEY}"
  model: "deepseek/deepseek-v3.2"
  temperature: 0.85
  max_tokens: 4096
  fallback:
    model: "anthropic/claude-haiku-4.5"
    temperature: 0.85
    max_tokens: 4096

agent:
  model: "moonshotai/kimi-k2.5"                   # tool-calling model for agent orchestration — best protocol compliance and fact quality in sim testing
  temperature: 0.4                               # standard transformer, moderate temp for varied but controlled tool calling
  max_tokens: 1024                               # needs headroom for tool call JSON — 512 risks truncation
  trace: false                                   # show agent thinking traces in chat (/traces to toggle)
  fallback:
    model: "anthropic/claude-haiku-4.5"
    temperature: 0.1
    max_tokens: 1024

classifier:
  model: "anthropic/claude-haiku-4.5"  # small, fast model that validates memory writes against fiction
  temperature: 0                        # deterministic — consistent REAL/FICTIONAL verdicts
  max_tokens: 64                        # only needs ~20 tokens, 64 for safety margin

vision:
  model: "google/gemini-3-flash-preview"  # VLM for image understanding (via OpenRouter, same base_url/api_key as llm)
  temperature: 0.3                         # low temp for accurate descriptions
  max_tokens: 512
  fallback:
    model: "anthropic/claude-haiku-4.5"
    temperature: 0.3
    max_tokens: 512

embed:
  base_url: "http://localhost:1234/v1"                          # LM Studio / Ollama / any OpenAI-compatible embedding server
  model: "text-embedding-nomic-embed-text-v1.5@q8_0"           # local embedding model
  dimension: 768                                                # vector size — must match your model (768 for nomic, 1536 for OpenAI, etc.)
  similarity_threshold: 0.85                                    # above this = duplicate fact (0.0-1.0)
  max_semantic_distance: 0.45                                   # facts farther than this skip auto-injection into context (0=identical, 1=unrelated). Lower is stricter.

search:
  tavily_api_key: "${TAVILY_API_KEY}"
  tavily_base_url: "https://api.tavily.com"  # default, rarely needs changing

ocr:
  vision_ocr_path: "macos-vision-ocr"    # path to macos-vision-ocr binary (or name if on PATH)
  confidence_threshold: 0.5               # below this → fallback to GLM-OCR (0.0-1.0)
  fallback:
    engine: "glm-ocr"                     # purpose-built OCR model (0.9B, MIT licensed)
    base_url: "http://localhost:1234/v1"  # LM Studio endpoint (same instance as embeddings)
    model: "glm-ocr"                      # model name in LM Studio

memory:
  db_path: "./her.db"
  recent_messages: 10            # sliding window size (compaction summaries cover older context)
  max_facts_in_context: 10       # top-K facts to inject
  extraction_interval: 10        # extract facts every N messages
  max_history_tokens: 3000       # history token budget for compaction — both triggers (real + estimated) fire at 75% of this.
  agent_context_budget: 16000    # agent model (Kimi K2.5) action history budget — when accumulated tool call history exceeds 75% of this, older actions get summarized. 0 = use 6000 default.
  max_fact_retries: 2            # per-fact retry limit per turn — after N rejections of the same fact, agent is told to move on. 0 = unlimited.
  auto_link_count: 3             # max links per new fact (0 = disabled). Links connect related facts into a knowledge graph.
  auto_link_threshold: 0.7       # min cosine similarity to create a link (0.0-1.0). Higher = stricter, fewer links.

scrub:
  enabled: true
  # tier 1 (hard redact) and tier 2 (tokenize) are always on
  # tier 3 (names, places, context) passes through by design

persona:
  prompt_file: "./prompt.md"
  persona_file: "./persona.md"
  agent_prompt_file: "./agent_prompt.md"
  rewrite_every_n_reflections: 3
  reflection_memory_threshold: 8     # trigger reflection when N+ facts extracted from one conversation
  max_trait_shift: 0.1               # max trait score change per rewrite cycle

scheduler:
  timezone: "America/New_York"
  quiet_hours_start: "23:00"
  quiet_hours_end: "07:00"
  max_proactive_per_day: 5
  morning_briefing: false
  mood_checkin: false
  medication_checkin: false
  proactive_followups: false
  auto_journal: false

todoist:
  api_key: "${TODOIST_API_KEY}"  # from https://app.todoist.com/app/settings/integrations/developer

weather:
  latitude: 0                    # your location — set via set_location tool or manually here
  longitude: 0                   # Open-Meteo is free, no API key needed
  temp_unit: "fahrenheit"        # "fahrenheit" or "celsius"
  wind_speed_unit: "mph"         # "mph" or "kmh"
  cache_ttl: 3600                # seconds between API refreshes (default: 1 hour)

voice:
  enabled: false                                                  # set true to accept voice memos
  stt:
    engine: "parakeet"                                            # "parakeet" or "cf-workers-ai"
    base_url: "http://localhost:8765"                              # parakeet-mlx-fastapi server
    model: "mlx-community/parakeet-tdt-0.6b-v2"                   # HuggingFace model ID or local path
  tts:
    enabled: false                                                # set true to reply with voice
    engine: "piper"                                               # "piper" (local) or future cloud options
    base_url: "http://localhost:8766"                              # piper TTS server
    model: "en_GB-southern_english_female-low"                     # piper voice model
    voice_id: "en_GB-southern_english_female-low"                  # voice preset
    speed: 1.0                                                    # speaking rate (1.0 = normal)
    reply_mode: "voice"                                           # "voice" (always voice reply) or "match" (reply in same format as input)
