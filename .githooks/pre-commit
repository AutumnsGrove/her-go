#!/bin/bash
# Pre-commit hook — Go code quality gates
# Blocks commits when code doesn't compile, isn't formatted, or has issues.
# Installed via: her hooks
# Bypass via:    git commit --no-verify

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
NC='\033[0m'

# Get staged Go files (only added, copied, or modified — not deleted)
go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

# Skip everything if no Go files are staged
if [ -z "$go_files" ]; then
    echo -e "${GREEN}✓ No Go files staged — skipping checks${NC}"
    exit 0
fi

echo -e "${BLUE}Pre-commit: checking staged Go files${NC}"
echo ""

checks_failed=0

# ============================================================================
# 1. GOFMT — canonical formatting
# ============================================================================
# Go has ONE format. No config files, no debates. gofmt is law.
echo -e "${DIM}Running gofmt...${NC}"

unformatted=$(gofmt -l $go_files 2>&1 || true)
if [ -z "$unformatted" ]; then
    echo -e "${GREEN}  ✓ gofmt${NC}"
else
    echo -e "${RED}  ✗ gofmt — unformatted files:${NC}"
    echo "$unformatted" | sed 's/^/    /'
    echo -e "${YELLOW}    Fix: gofmt -w .${NC}"
    checks_failed=1
fi

# ============================================================================
# 2. GO VET — static analysis
# ============================================================================
# Catches real bugs the compiler misses: bad printf formats, unreachable code,
# copying locks, etc. Think of it as a lightweight linter that ships with Go.
echo -e "${DIM}Running go vet...${NC}"

vet_output=$(go vet ./... 2>&1 || true)
if [ -z "$vet_output" ]; then
    echo -e "${GREEN}  ✓ go vet${NC}"
else
    echo -e "${RED}  ✗ go vet — issues found:${NC}"
    echo "$vet_output" | sed 's/^/    /'
    checks_failed=1
fi

# ============================================================================
# 3. GO BUILD — the big one
# ============================================================================
# If it doesn't compile, it doesn't commit. Period.
# This is the single most valuable check — catches typos, missing imports,
# type mismatches, and any other compile error before it hits the repo.
echo -e "${DIM}Running go build...${NC}"

build_output=$(go build ./... 2>&1 || true)
if [ $? -eq 0 ] && [ -z "$build_output" ]; then
    echo -e "${GREEN}  ✓ go build${NC}"
else
    # go build exit code gets eaten by the capture, so check output
    if go build ./... 2>/dev/null; then
        echo -e "${GREEN}  ✓ go build${NC}"
    else
        echo -e "${RED}  ✗ go build — compilation failed:${NC}"
        go build ./... 2>&1 | sed 's/^/    /' || true
        checks_failed=1
    fi
fi

# ============================================================================
# 4. GO MOD TIDY — dependency hygiene
# ============================================================================
# Checks if go.mod/go.sum are in sync. Runs go mod tidy in a temp copy
# to avoid mutating the working tree during a commit.
echo -e "${DIM}Checking go.mod tidiness...${NC}"

# Copy go.mod and go.sum, run tidy, compare
cp go.mod go.mod.pre-commit-backup
cp go.sum go.sum.pre-commit-backup 2>/dev/null || true

go mod tidy 2>/dev/null

if diff -q go.mod go.mod.pre-commit-backup >/dev/null 2>&1 && \
   diff -q go.sum go.sum.pre-commit-backup >/dev/null 2>&1; then
    echo -e "${GREEN}  ✓ go mod tidy${NC}"
else
    echo -e "${RED}  ✗ go mod tidy — go.mod/go.sum out of sync${NC}"
    echo -e "${YELLOW}    Fix: go mod tidy${NC}"
    checks_failed=1
fi

# Restore originals (tidy may have changed them)
mv go.mod.pre-commit-backup go.mod
mv go.sum.pre-commit-backup go.sum 2>/dev/null || true

# ============================================================================
# 5. SECRETS SCAN — catch API keys before they hit the repo
# ============================================================================
echo -e "${DIM}Scanning for secrets...${NC}"

# Patterns that should never appear in a commit
secrets_found=0
staged_diff=$(git diff --cached)

# OpenRouter API key (used by this project)
if echo "$staged_diff" | grep -qE 'sk-or-v1-[a-zA-Z0-9]{64,}'; then
    echo -e "${RED}  ✗ OpenRouter API key detected in diff${NC}"
    secrets_found=1
fi

# OpenAI-style keys
if echo "$staged_diff" | grep -qE 'sk-[a-zA-Z0-9]{32,}'; then
    # Exclude OpenRouter keys (already caught) and common false positives
    non_or_keys=$(echo "$staged_diff" | grep -E 'sk-[a-zA-Z0-9]{32,}' | grep -v 'sk-or-v1-' | grep -v 'sk-ant-' || true)
    if [ -n "$non_or_keys" ]; then
        echo -e "${RED}  ✗ Possible API key detected (sk-...) in diff${NC}"
        secrets_found=1
    fi
fi

# Anthropic keys
if echo "$staged_diff" | grep -qE 'sk-ant-api[0-9]{2}-[a-zA-Z0-9_-]{93,}'; then
    echo -e "${RED}  ✗ Anthropic API key detected in diff${NC}"
    secrets_found=1
fi

# Telegram bot tokens (this IS a Telegram bot project)
if echo "$staged_diff" | grep -qE '[0-9]{8,10}:[A-Za-z0-9_-]{35}'; then
    echo -e "${RED}  ✗ Possible Telegram bot token detected in diff${NC}"
    secrets_found=1
fi

# Private keys — use grep -F for the fixed prefix to avoid BSD grep choking on leading dashes
if echo "$staged_diff" | grep -qF -- '-----BEGIN ' | grep -q 'PRIVATE KEY'; then
    echo -e "${RED}  ✗ Private key detected in diff${NC}"
    secrets_found=1
fi
# Also catch the exact headers directly
if echo "$staged_diff" | grep -qF 'PRIVATE KEY-----'; then
    echo -e "${RED}  ✗ Private key detected in diff${NC}"
    secrets_found=1
fi

# Google API keys — escape the character class to avoid BSD grep range issues
if echo "$staged_diff" | grep -qE 'AIza[0-9A-Za-z_-]{35}'; then
    echo -e "${RED}  ✗ Google API key detected in diff${NC}"
    secrets_found=1
fi

# Sensitive filenames being committed
sensitive_files=$(git diff --cached --name-only | grep -E '^(\.env|secrets\.json|credentials\.json|id_rsa|id_ed25519|.*\.pem)$' || true)
if [ -n "$sensitive_files" ]; then
    echo -e "${RED}  ✗ Sensitive file staged: $sensitive_files${NC}"
    secrets_found=1
fi

if [ $secrets_found -eq 1 ]; then
    echo -e "${YELLOW}    Secrets belong in config.yaml (gitignored), not in code.${NC}"
    checks_failed=1
else
    echo -e "${GREEN}  ✓ no secrets${NC}"
fi

# ============================================================================
# 6. HELP YAML SYNC — new commands must appear in help.yaml
# ============================================================================
# If you register a new /command in bot/telegram.go, it needs an entry in
# bot/help.yaml so users can discover it via /help. Catches the classic
# "added a command but forgot to document it" bug.
# Suppress: add "// help-ok" on the Handle line (for internal-only commands)

if echo "$go_files" | grep -q 'bot/'; then
    echo -e "${DIM}Checking help.yaml sync...${NC}"

    # Extract /commands registered in staged bot/*.go files
    # Pattern: b.tb.Handle("/foo" or bot.Handle("/foo"
    registered=$(git diff --cached -U0 -- 'bot/*.go' | \
        grep '^+' | grep -v '^+++' | \
        grep -oE 'Handle\s*\(\s*"\/[a-z_]+"' | \
        grep -oE '\/[a-z_]+' | sort -u || true)

    if [ -n "$registered" ]; then
        help_missing=""
        for cmd in $registered; do
            # Check if the command appears in help.yaml
            if ! grep -q "cmd:.*${cmd}" bot/help.yaml 2>/dev/null; then
                # Check for help-ok suppression on the Handle line
                if ! git diff --cached -U0 -- 'bot/*.go' | \
                    grep "Handle.*\"${cmd}\"" | grep -q 'help-ok'; then
                    help_missing="${help_missing}  ${cmd}\n"
                fi
            fi
        done

        if [ -n "$help_missing" ]; then
            echo -e "${RED}  ✗ New commands not in bot/help.yaml:${NC}"
            echo -e "$help_missing"
            echo -e "${YELLOW}    Fix: Add entries to bot/help.yaml${NC}"
            echo -e "${YELLOW}    Suppress: add ${BLUE}// help-ok${YELLOW} on the Handle line${NC}"
            checks_failed=1
        else
            echo -e "${GREEN}  ✓ help.yaml in sync${NC}"
        fi
    else
        echo -e "${GREEN}  ✓ help.yaml sync (no new commands)${NC}"
    fi
else
    echo -e "${GREEN}  ✓ help.yaml sync skipped (no bot/ files staged)${NC}"
fi

# ============================================================================
# 7. DATA PRIMACY — no hardcoded model strings in Go code
# ============================================================================
# Model identifiers (e.g., "qwen/qwen3-235b") belong in config.yaml, read
# via cfg.Models.*. A model string in .go source means someone will forget
# to update it when the model changes. The config is the single source of truth.
# Suppress: add "// model-ok" on the same line (for test fixtures, comments)

echo -e "${DIM}Checking for hardcoded model strings...${NC}"

# Common model string patterns from OpenRouter
model_hits=$(git diff --cached -U0 -- '*.go' | \
    grep '^+' | grep -v '^+++' | \
    grep -v '_test\.go' | \
    grep -v 'model-ok' | \
    grep -v '^\+\s*//' | \
    grep -oE '"(qwen|deepseek|anthropic|google|moonshotai|openai|meta-llama|mistralai)/[a-zA-Z0-9._-]+"' || true)

if [ -z "$model_hits" ]; then
    echo -e "${GREEN}  ✓ no hardcoded models${NC}"
else
    echo -e "${RED}  ✗ Hardcoded model string in Go code:${NC}"
    echo "$model_hits" | sort -u | sed 's/^/    /'
    echo -e "${YELLOW}    Fix: Use cfg.Models.* from config.yaml${NC}"
    echo -e "${YELLOW}    Suppress: add ${BLUE}// model-ok${YELLOW} on the line${NC}"
    checks_failed=1
fi

# ============================================================================
# 8. TOOL REGISTRATION — tools must be imported in the correct agent file
# ============================================================================
# Each tool.yaml declares `agent: main`, `agent: memory`, or `agent: [main, memory]`.
# The tool's init() only runs if the package is blank-imported in the right file:
#   main   → agent/agent.go
#   memory → agent/memory_agent.go
# Missing the import means the tool silently doesn't exist at runtime.
# Tools without a tool.yaml (like use_tools) are skipped — they're meta-tools.

echo -e "${DIM}Checking tool registration...${NC}"

tool_errors=""
for yaml in tools/*/tool.yaml; do
    dir=$(dirname "$yaml")
    name=$(basename "$dir")
    pkg="her/${dir}"

    # Read the agent field from tool.yaml
    agent_val=$(grep '^agent:' "$yaml" 2>/dev/null | sed 's/^agent:\s*//' | tr -d '[]' || true)

    if [ -z "$agent_val" ]; then
        tool_errors="${tool_errors}  ${name}: missing 'agent' field in tool.yaml\n"
        continue
    fi

    # Check each declared agent
    for agent in $(echo "$agent_val" | tr ',' ' '); do
        agent=$(echo "$agent" | tr -d ' ')
        case "$agent" in
            main)
                if ! grep -q "\"${pkg}\"" agent/agent.go 2>/dev/null; then
                    tool_errors="${tool_errors}  ${name} (agent: main) → missing from agent/agent.go\n"
                fi
                ;;
            memory)
                if ! grep -q "\"${pkg}\"" agent/memory_agent.go 2>/dev/null; then
                    tool_errors="${tool_errors}  ${name} (agent: memory) → missing from agent/memory_agent.go\n"
                fi
                ;;
        esac
    done
done

if [ -n "$tool_errors" ]; then
    echo -e "${RED}  ✗ Tool registration mismatch:${NC}"
    echo -e "$tool_errors"
    echo -e "${YELLOW}    Each tool.yaml declares its agent. The matching file must import it:${NC}"
    echo -e "${YELLOW}      agent: main   → ${BLUE}_ \"her/tools/<name>\"${YELLOW} in agent/agent.go${NC}"
    echo -e "${YELLOW}      agent: memory → ${BLUE}_ \"her/tools/<name>\"${YELLOW} in agent/memory_agent.go${NC}"
    checks_failed=1
else
    echo -e "${GREEN}  ✓ tool registration${NC}"
fi

# ============================================================================
# RESULTS
# ============================================================================
echo ""
if [ $checks_failed -eq 1 ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  Pre-commit checks failed.${NC}"
    echo -e "${RED}  Fix the issues above, then try again.${NC}"
    echo -e "${DIM}  Bypass: git commit --no-verify${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
else
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  ✓ All checks passed${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 0
fi
