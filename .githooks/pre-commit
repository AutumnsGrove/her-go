#!/bin/bash
# Pre-commit hook — Go code quality gates
# Blocks commits when code doesn't compile, isn't formatted, or has issues.
# Installed via: her hooks
# Bypass via:    git commit --no-verify

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
NC='\033[0m'

# Get staged Go files (only added, copied, or modified — not deleted)
go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

# Skip everything if no Go files are staged
if [ -z "$go_files" ]; then
    echo -e "${GREEN}✓ No Go files staged — skipping checks${NC}"
    exit 0
fi

echo -e "${BLUE}Pre-commit: checking staged Go files${NC}"
echo ""

checks_failed=0

# ============================================================================
# 1. GOFMT — canonical formatting
# ============================================================================
# Go has ONE format. No config files, no debates. gofmt is law.
echo -e "${DIM}Running gofmt...${NC}"

unformatted=$(gofmt -l $go_files 2>&1 || true)
if [ -z "$unformatted" ]; then
    echo -e "${GREEN}  ✓ gofmt${NC}"
else
    echo -e "${RED}  ✗ gofmt — unformatted files:${NC}"
    echo "$unformatted" | sed 's/^/    /'
    echo -e "${YELLOW}    Fix: gofmt -w .${NC}"
    checks_failed=1
fi

# ============================================================================
# 2. GO VET — static analysis
# ============================================================================
# Catches real bugs the compiler misses: bad printf formats, unreachable code,
# copying locks, etc. Think of it as a lightweight linter that ships with Go.
echo -e "${DIM}Running go vet...${NC}"

vet_output=$(go vet ./... 2>&1 || true)
if [ -z "$vet_output" ]; then
    echo -e "${GREEN}  ✓ go vet${NC}"
else
    echo -e "${RED}  ✗ go vet — issues found:${NC}"
    echo "$vet_output" | sed 's/^/    /'
    checks_failed=1
fi

# ============================================================================
# 3. GO BUILD — the big one
# ============================================================================
# If it doesn't compile, it doesn't commit. Period.
# This is the single most valuable check — catches typos, missing imports,
# type mismatches, and any other compile error before it hits the repo.
echo -e "${DIM}Running go build...${NC}"

build_output=$(go build ./... 2>&1 || true)
if [ $? -eq 0 ] && [ -z "$build_output" ]; then
    echo -e "${GREEN}  ✓ go build${NC}"
else
    # go build exit code gets eaten by the capture, so check output
    if go build ./... 2>/dev/null; then
        echo -e "${GREEN}  ✓ go build${NC}"
    else
        echo -e "${RED}  ✗ go build — compilation failed:${NC}"
        go build ./... 2>&1 | sed 's/^/    /' || true
        checks_failed=1
    fi
fi

# ============================================================================
# 4. GO MOD TIDY — dependency hygiene
# ============================================================================
# Checks if go.mod/go.sum are in sync. Runs go mod tidy in a temp copy
# to avoid mutating the working tree during a commit.
echo -e "${DIM}Checking go.mod tidiness...${NC}"

# Copy go.mod and go.sum, run tidy, compare
cp go.mod go.mod.pre-commit-backup
cp go.sum go.sum.pre-commit-backup 2>/dev/null || true

go mod tidy 2>/dev/null

if diff -q go.mod go.mod.pre-commit-backup >/dev/null 2>&1 && \
   diff -q go.sum go.sum.pre-commit-backup >/dev/null 2>&1; then
    echo -e "${GREEN}  ✓ go mod tidy${NC}"
else
    echo -e "${RED}  ✗ go mod tidy — go.mod/go.sum out of sync${NC}"
    echo -e "${YELLOW}    Fix: go mod tidy${NC}"
    checks_failed=1
fi

# Restore originals (tidy may have changed them)
mv go.mod.pre-commit-backup go.mod
mv go.sum.pre-commit-backup go.sum 2>/dev/null || true

# ============================================================================
# 5. SECRETS SCAN — catch API keys before they hit the repo
# ============================================================================
echo -e "${DIM}Scanning for secrets...${NC}"

# Patterns that should never appear in a commit
secrets_found=0
staged_diff=$(git diff --cached)

# OpenRouter API key (used by this project)
if echo "$staged_diff" | grep -qE 'sk-or-v1-[a-zA-Z0-9]{64,}'; then
    echo -e "${RED}  ✗ OpenRouter API key detected in diff${NC}"
    secrets_found=1
fi

# OpenAI-style keys
if echo "$staged_diff" | grep -qE 'sk-[a-zA-Z0-9]{32,}'; then
    # Exclude OpenRouter keys (already caught) and common false positives
    non_or_keys=$(echo "$staged_diff" | grep -E 'sk-[a-zA-Z0-9]{32,}' | grep -v 'sk-or-v1-' | grep -v 'sk-ant-' || true)
    if [ -n "$non_or_keys" ]; then
        echo -e "${RED}  ✗ Possible API key detected (sk-...) in diff${NC}"
        secrets_found=1
    fi
fi

# Anthropic keys
if echo "$staged_diff" | grep -qE 'sk-ant-api[0-9]{2}-[a-zA-Z0-9_-]{93,}'; then
    echo -e "${RED}  ✗ Anthropic API key detected in diff${NC}"
    secrets_found=1
fi

# Telegram bot tokens (this IS a Telegram bot project)
if echo "$staged_diff" | grep -qE '[0-9]{8,10}:[A-Za-z0-9_-]{35}'; then
    echo -e "${RED}  ✗ Possible Telegram bot token detected in diff${NC}"
    secrets_found=1
fi

# Private keys
if echo "$staged_diff" | grep -qE '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'; then
    echo -e "${RED}  ✗ Private key detected in diff${NC}"
    secrets_found=1
fi

# Google API keys
if echo "$staged_diff" | grep -qE 'AIza[0-9A-Za-z-_]{35}'; then
    echo -e "${RED}  ✗ Google API key detected in diff${NC}"
    secrets_found=1
fi

# Sensitive filenames being committed
sensitive_files=$(git diff --cached --name-only | grep -E '^(\.env|secrets\.json|credentials\.json|id_rsa|id_ed25519|.*\.pem)$' || true)
if [ -n "$sensitive_files" ]; then
    echo -e "${RED}  ✗ Sensitive file staged: $sensitive_files${NC}"
    secrets_found=1
fi

if [ $secrets_found -eq 1 ]; then
    echo -e "${YELLOW}    Secrets belong in config.yaml (gitignored), not in code.${NC}"
    checks_failed=1
else
    echo -e "${GREEN}  ✓ no secrets${NC}"
fi

# ============================================================================
# RESULTS
# ============================================================================
echo ""
if [ $checks_failed -eq 1 ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  Pre-commit checks failed.${NC}"
    echo -e "${RED}  Fix the issues above, then try again.${NC}"
    echo -e "${DIM}  Bypass: git commit --no-verify${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
else
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  ✓ All checks passed${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 0
fi
