# Database (contains all personal data)
her.db
her.db-journal
her.db-wal
her.db-shm

# Evolving persona (bot-authored, versioned in DB)
persona.md

# Config with secrets (use config.yaml.example as template)
config.yaml

# Generated wrangler config (derived from config.yaml by `her dev`)
worker/wrangler.toml

# Environment files
.env
.env.*

# Binary
her-go
her-go.exe
her

# Go
vendor/
.gocache/

# Python
__pycache__/
*.pyc

# Voice memos (audio files from Telegram)
voice_memos/
voice_cache/
*.ogg
*.wav

# Claude Code (session state, not shared config)
.claude/worktrees/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
logs/
her.log
her-*.log

# Skill sidecar databases (execution history)
skills/**/*.db
skills/**/*.db-journal
skills/**/*.db-wal
skills/**/*.db-shm

# Simulation results (personal data from test runs)
sims/sim.db
sims/sim.db-journal
sims/sim.db-wal
sims/sim.db-shm
sims/results/

